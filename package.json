{
  "name": "ld-rune-builder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf:types": "wrangler types",
    "db:local": "wrangler d1 migrations apply fluz-ld-tools --local",
    "db:remote": "wrangler d1 migrations apply fluz-ld-tools --remote",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "javascript-lp-solver": "^1.0.3",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "latest",
    "@cloudflare/workers-types": "latest",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.4",
    "typescript": "latest",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "latest"
  },
  "overrides": {
    "sharp": "0.35.3"
  }
}
